<div class="dashboard-container">
  <!-- Hero/Welcome Section -->
  <div class="landing-hero">
    <div class="hero-text">
      <h1 class="hero-title">Welcome, <span class="highlight"><%= user.username %></span></h1>
      <p class="hero-subtitle">Discover, play, and enjoy your favorite music</p>
    </div>
  </div>

  <!-- Dashboard Stats Overview -->
  <div class="stats-overview">
    <!-- Recently Played stat removed -->
    <div class="stat-card">
      <div class="stat-icon">
        <i class="fas fa-list"></i>
      </div>
      <div class="stat-info">
        <h3 id="stat-playlists-count"><%= user.playlists ? user.playlists.length : 0 %></h3>
        <p>Playlists</p>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon">
        <i class="fas fa-heart"></i>
      </div>
      <div class="stat-info">
        <h3 id="stat-favorites-count"><%= user.favorites ? user.favorites.length : 0 %></h3>
        <p>Favorites</p>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon">
        <i class="fas fa-user"></i>
      </div>
      <div class="stat-info">
        <h3><%= user.username %></h3>
        <p><%= user.email %></p>
      </div>
    </div>
  </div>

  <div class="dashboard-content">
    <!-- Recently Played section removed -->

    <!-- Playlists Section -->
    <section class="dashboard-section">
      <div class="section-header">
        <i class="fas fa-list"></i>
        <h2>Your Playlists</h2>
        <a href="/playlists" class="view-all-btn">View All</a>
      </div>
      <div class="playlists-grid">
        <% if (user.playlists && user.playlists.length > 0) { %>
          <% user.playlists.slice(0, 6).forEach(playlist => { %>
            <a href="/playlists/view/<%= playlist._id %>" class="playlist-card">
              <div class="playlist-icon">
                <i class="fas fa-music"></i>
              </div>
              <div class="playlist-info">
                <h4><%= playlist.name %></h4>
                <p><%= playlist.songs.length %> songs</p>
              </div>
            </a>
          <% }) %>
        <% } else { %>
          <div class="empty-state">
            <i class="fas fa-list"></i>
            <p>No playlists yet</p>
            <a href="/playlists" class="create-btn">Create Playlist</a>
          </div>
        <% } %>
      </div>
    </section>

    <!-- Account Settings Section -->
    <section class="dashboard-section">
      <div class="section-header">
        <i class="fas fa-cog"></i>
        <h2>Account Settings</h2>
      </div>
      
      <div class="settings-grid">
        <!-- Change Username -->
        <div class="setting-card">
          <div class="setting-icon">
            <i class="fas fa-user"></i>
          </div>
          <div class="setting-content">
            <h3>Change Username</h3>
            <form method="POST" action="/dashboard/update-username" class="setting-form">
              <div class="form-group">
                <input type="text" name="username" placeholder="New username" value="<%= user.username %>" class="form-input" required>
              </div>
              <button type="submit" class="save-btn">
                <i class="fas fa-save"></i>
                Save
              </button>
            </form>
          </div>
        </div>

        <!-- Change Password -->
        <div class="setting-card">
          <div class="setting-icon">
            <i class="fas fa-lock"></i>
          </div>
          <div class="setting-content">
            <h3>Change Password</h3>
            <form method="POST" action="/dashboard/update-password" class="setting-form">
              <div class="form-group">
                <input type="password" name="currentPassword" placeholder="Current password" class="form-input" required>
              </div>
              <div class="form-group">
                <input type="password" name="newPassword" placeholder="New password" class="form-input" required>
              </div>
              <button type="submit" class="save-btn">
                <i class="fas fa-save"></i>
                Save
              </button>
            </form>
          </div>
        </div>
      </div>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="success-message">
          <i class="fas fa-check-circle"></i>
          <span><%= success %></span>
        </div>
      <% } %>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-message">
          <i class="fas fa-exclamation-circle"></i>
          <span><%= error %></span>
        </div>
      <% } %>
    </section>

    <!-- Logout Button -->
    <div class="logout-section">
      <a href="/logout" class="logout-btn-large">
        <i class="fas fa-power-off"></i>
        Logout
      </a>
    </div>
  </div>
</div>

