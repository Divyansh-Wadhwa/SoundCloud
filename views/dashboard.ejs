</style>

<script>
  (function() {
    const recentContainer = document.getElementById('recently-played-container');
    const recentEmpty = document.getElementById('recently-empty');
    const statRecent = document.getElementById('stat-recent-count');
    const statPlaylists = document.getElementById('stat-playlists-count');
    const statFavorites = document.getElementById('stat-favorites-count');

    function fmtDate(d) {
      try { return new Date(d).toLocaleDateString(); } catch(e) { return ''; }
    }

    function buildSongCard(item, favorites) {
      const song = item.song;
      const isFav = favorites && favorites.includes(song._id);
      return `
        <div class="song-card">
          <div class="song-thumbnail">
            ${song.thumbnail ? `<img src="${song.thumbnail}" alt="${song.title}">` : '<i class="fas fa-music"></i>'}
            <button class="play-btn-overlay" onclick="playSong('${song._id}')"><i class="fas fa-play"></i></button>
            <button class="favorite-btn-card ${isFav ? 'active' : ''}" onclick="toggleFavorite('${song._id}', this)"><i class="fas fa-heart"></i></button>
          </div>
          <div class="song-info">
            <h4>${song.title}</h4>
            <p>${song.artist || ''}</p>
            <span class="played-time">Played ${fmtDate(item.playedAt)}</span>
          </div>
        </div>
      `;
    }

    async function refreshDashboard() {
      try {
        const res = await fetch('/api/dashboard-stats', { headers: { 'Accept': 'application/json' } });
        if (!res.ok) return;
        const data = await res.json();

        if (statPlaylists) statPlaylists.textContent = data.playlistsCount || 0;
        if (statFavorites) statFavorites.textContent = data.favoritesCount || 0;
        if (statRecent) statRecent.textContent = data.recentlyPlayed ? data.recentlyPlayed.length : 0;

        if (recentContainer) {
          if (data.recentlyPlayed && data.recentlyPlayed.length) {
            recentContainer.innerHTML = data.recentlyPlayed.map(rp => buildSongCard(rp, [] )).join('');
            if (recentEmpty) recentEmpty.style.display = 'none';
          } else {
            recentContainer.innerHTML = '';
            if (recentEmpty) recentEmpty.style.display = '';
          }
        }
      } catch (err) {
        console.warn('Failed to refresh dashboard:', err);
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      // initial fetch
      refreshDashboard();
      // poll every 10 seconds
      setInterval(refreshDashboard, 10000);
    });
  })();
</script>
