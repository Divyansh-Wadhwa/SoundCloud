      flex-direction: column;
      align-items: flex-start;
    }

    .playlist-cover-large {
      width: 200px;
      height: 200px;
    }

    .playlist-name-hero {
      font-size: 36px;
    }

    .hero-actions {
      width: 100%;
    }

    .btn-play-all {
      flex: 1;
      justify-content: center;
    }

    .songs-section,
    .add-songs-section {
      padding: 0 24px;
    }

    .songs-header {
      display: none;
    }

    .song-row {
      grid-template-columns: 1fr 60px;
      gap: 12px;
    }

    .col-number,
    .col-artist {
      display: none;
    }

    .col-title {
      grid-column: 1;
    }

    .col-actions {
      grid-column: 2;
    }

    .btn-remove {
      opacity: 1;
    }

    .available-songs-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 16px;
    }
