  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-in {
    animation: fadeIn 0.5s ease-out forwards;
    opacity: 0;
  }
</style>

  <script>
    (function(){
      // Build playlist queue from server-rendered data attribute (avoids inline EJS in script)
      const _rawQueue = (function(){
        try {
          const el = document.getElementById('playlistQueueData');
          return el && el.dataset && el.dataset.queue ? JSON.parse(el.dataset.queue) : [];
        } catch(e){ return []; }
      })();
      const playlistQueue = Array.isArray(_rawQueue) ? _rawQueue.map(s => ({ 
        id: s._id ? s._id.toString() : (s.id ? s.id.toString() : null),
        file: s.file, 
        title: s.title, 
        artist: s.artist, 
        thumbnail: s.thumbnail || s.cover || '/images/default-cover.png' 
      })) : [];

      // Helper: run callback when global player is available
      function whenGlobalReady(cb){
        if(typeof window.playSongInBottomBar !== 'undefined') return cb();
        const handler = function(){ 
          window.removeEventListener('globalPlayerReady', handler); 
          cb(); 
        };
        window.addEventListener('globalPlayerReady', handler);
      }

      // Play All button - plays first song and sets queue
      const playAllBtn = document.getElementById('playAllBtn');
      if(playAllBtn && playlistQueue.length > 0){
        playAllBtn.addEventListener('click', ()=>{
          console.log('Play All clicked, queue:', playlistQueue);
          const firstSong = playlistQueue[0];
          console.log('First song:', firstSong);
          if(firstSong && firstSong.id){
            whenGlobalReady(()=>{
              console.log('Calling playSongInBottomBar with ID:', firstSong.id);
              window.playSongInBottomBar(firstSong.id);
            });
          } else {
            console.error('First song or ID missing:', firstSong);
          }
        });
      } else {
        console.log('Play All button not found or queue empty');
      }

      // Individual song play from list
      window.playSongFromPlaylist = function(idx){
        if(idx >= 0 && idx < playlistQueue.length){
          const song = playlistQueue[idx];
          if(song && song.id){
            whenGlobalReady(()=>{
              window.playSongInBottomBar(song.id);
            });
          }
        }
      };

      // Preview song in "Add More Songs" section
      window.previewSong = function(file, title, artist, thumbnail){
        // Create a temporary single-song queue and play
        whenGlobalReady(()=>{
          // Find song by file path if possible, or just alert
          const matchingSong = playlistQueue.find(s => s.file === file);
          if(matchingSong && matchingSong.id){
            window.playSongInBottomBar(matchingSong.id);
          } else {
            alert('Preview: ' + title + ' by ' + artist + '\n(Add this song to play it)');
          }
        });
      };

      // Smooth scroll for "Add Songs" links
      document.querySelectorAll('a[href="#addSongsSection"]').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const section = document.getElementById('addSongsSection');
          if(section){
            section.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });

      // Apply animation delays declared in data-delay attributes
      document.querySelectorAll('[data-delay]').forEach(el => {
        try { el.style.animationDelay = (el.dataset.delay || '0') + 's'; } catch(e){}
      });

      // Wire up delete buttons to show modal and submit form safely
      document.querySelectorAll('.btn-delete').forEach(btn => {
        btn.addEventListener('click', () => {
          const raw = btn.dataset.playlistName;
          let name = '';
          try { name = JSON.parse(raw); } catch(e) { name = raw || ''; }
          if (typeof window.showModal === 'function') {
            window.showModal({
              title: 'Delete Playlist',
              message: 'Are you sure you want to delete "' + name + '"? This action cannot be undone.',
              danger: true,
              confirmText: 'Delete',
              onConfirm: function(){ btn.closest('form').submit(); }
            });
          } else {
            if (confirm('Delete playlist "' + name + '"?')) btn.closest('form').submit();
          }
        });
      });

      // Wire play icons (rows) to use the in-script player function
      document.querySelectorAll('.play-icon[data-idx]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const idx = Number(btn.dataset.idx);
          if (!Number.isNaN(idx) && typeof window.playSongFromPlaylist === 'function') {
            window.playSongFromPlaylist(idx);
          }
          e.stopPropagation();
        });
      });

      // Wire preview buttons in available songs
      document.querySelectorAll('.preview-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const file = btn.dataset.file;
          const title = btn.dataset.title || '';
          const artist = btn.dataset.artist || '';
          const thumb = btn.dataset.thumb || '';
          if (typeof window.previewSong === 'function') {
            window.previewSong(file, title, artist, thumb);
          }
          e.stopPropagation();
        });
      });
    })();
</script>

