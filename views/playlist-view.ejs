<div class="playlist-view-page">
  <div id="playlistQueueData" data-queue='<%- JSON.stringify(playlist.songs || []) %>' style="display:none"></div>
  <!-- Hero Header with Playlist Info -->
  <div class="playlist-hero">
    <div class="hero-background">
      <% if (playlist.songs && playlist.songs.length > 0 && playlist.songs[0].thumbnail) { %>
        <img src="<%= playlist.songs[0].thumbnail %>" alt="<%= playlist.name %>" class="hero-bg-image">
      <% } %>
      <div class="hero-gradient"></div>
    </div>
    
    <div class="hero-content-wrapper">
      <div class="hero-main">
        <div class="playlist-left-section">
          <div class="playlist-cover-large">
            <% if (playlist.songs && playlist.songs.length > 0 && playlist.songs[0].thumbnail) { %>
              <img src="<%= playlist.songs[0].thumbnail %>" alt="<%= playlist.name %>">
            <% } else { %>
              <div class="cover-placeholder-large">
                <i class="fas fa-music"></i>
              </div>
            <% } %>
          </div>
          <a href="/playlists" class="btn-back">
            <i class="fas fa-arrow-left"></i>
            <span>Back</span>
          </a>
        </div>
        
        <div class="playlist-details">
          <span class="playlist-badge">PLAYLIST</span>
          <h1 class="playlist-name-hero"><%= playlist.name %></h1>
          <div class="playlist-stats">
            <span class="stat-item">
              <i class="fas fa-music"></i>
              <%= playlist.songs ? playlist.songs.length : 0 %> <%= playlist.songs && playlist.songs.length === 1 ? 'song' : 'songs' %>
            </span>
          </div>
          
          <div class="hero-actions">
            <% if (playlist.songs && playlist.songs.length > 0) { %>
              <button class="btn-play-all" id="playAllBtn">
                <i class="fas fa-play"></i>
                <span>Play All</span>
              </button>
            <% } %>
            <a href="#addSongsSection" class="btn-add-songs">
              <i class="fas fa-plus"></i>
              <span>Add Songs</span>
            </a>
              <form action="/playlists/<%= playlist._id %>/delete" method="POST" style="display:inline;">
                <button type="button" class="btn-delete" data-playlist-name="<%- JSON.stringify(playlist.name) %>">
                  <i class="fas fa-trash"></i>
                </button>
              </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Songs List -->
  <% if (playlist.songs && playlist.songs.length > 0) { %>
    <div class="songs-section">
      <div class="songs-header">
        <div class="col-number">#</div>
        <div class="col-title">Title</div>
        <div class="col-artist">Artist</div>
        <div class="col-actions"></div>
      </div>
      
      <div class="songs-list">
        <% playlist.songs.forEach((song, idx) => { %>
          <div class="song-row fade-in" data-idx="<%= idx %>" data-song-id="<%= song._id %>" data-delay="<%= (idx * 0.03) %>">
            <div class="col-number">
              <span class="song-number"><%= idx + 1 %></span>
              <button class="play-icon" data-idx="<%= idx %>">
                <i class="fas fa-play"></i>
              </button>
            </div>
            
            <div class="col-title">
              <img src="<%= song.thumbnail || song.cover || '/images/default-cover.png' %>" alt="<%= song.title %>" class="song-thumbnail">
              <div class="song-title-info">
                <div class="song-title-text"><%= song.title %></div>
              </div>
            </div>
            
            <div class="col-artist">
              <span class="song-artist-text"><%= song.artist %></span>
            </div>
            
            <div class="col-actions">
              <form action="/playlists/<%= playlist._id %>/remove/<%= song._id %>" method="POST" style="display:inline;">
                <button type="submit" class="btn-remove" title="Remove from playlist">
                  <i class="fas fa-times"></i>
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% } else { %>
    <div class="empty-playlist-state">
      <div class="empty-icon-large">
        <i class="fas fa-music"></i>
      </div>
      <h3 class="empty-title-large">Your playlist is empty</h3>
      <p class="empty-message-large">Add some songs below to start building your perfect soundtrack</p>
      <a href="#addSongsSection" class="btn-add-first">
        <i class="fas fa-plus"></i>
        Add Your First Song
      </a>
    </div>
  <% } %>

  <!-- Add Songs Section -->
  <section id="addSongsSection" class="add-songs-section">
    <h2 class="section-title">
      <i class="fas fa-plus-circle"></i>
      Add More Songs
    </h2>
    
    <% if (songs && songs.length > 0) { %>
      <div class="available-songs-grid">
           <% songs.forEach((song, idx) => { 
             const alreadyAdded = (playlist.songs || []).find(s => s._id.toString() === song._id.toString());
             if(!alreadyAdded){ %>
          <div class="available-song-card fade-in" data-delay="<%= (idx * 0.02) %>">
            <div class="available-song-cover">
              <img src="<%= song.thumbnail || '/images/default-cover.png' %>" alt="<%= song.title %>">
              <div class="cover-overlay-add">
                <button class="preview-btn" data-file=<%- JSON.stringify(song.file) %> data-title=<%- JSON.stringify(song.title) %> data-artist=<%- JSON.stringify(song.artist) %> data-thumb=<%- JSON.stringify(song.thumbnail || '/images/default-cover.png') %>>
                  <i class="fas fa-play"></i>
                </button>
              </div>
            </div>
            
            <div class="available-song-info">
              <h4 class="available-song-title"><%= song.title %></h4>
              <p class="available-song-artist"><%= song.artist %></p>
              
              <form action="/playlists/<%= playlist._id %>/add/<%= song._id %>" method="POST">
                <button type="submit" class="btn-add-to-playlist">
                  <i class="fas fa-plus"></i>
                  Add to Playlist
                </button>
              </form>
            </div>
          </div>
        <% } %>
        <% }) %>
      </div>
    <% } else { %>
      <p class="no-more-songs">All available songs have been added to this playlist!</p>
    <% } %>
  </section>
</div>

