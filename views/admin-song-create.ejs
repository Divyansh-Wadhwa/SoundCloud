<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Add Song' %> - Admin</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

<div class="admin-modern-container">
  <div class="admin-modern-card">
    <div class="card-header">
      <div class="header-icon">
        <i class="fas fa-music"></i>
      </div>
      <h1 class="card-title">Add New Song</h1>
      <p class="card-subtitle">Upload a new track to your collection</p>
    </div>

    <form action="/admin/songs/create" method="POST" enctype="multipart/form-data" class="modern-form">
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">
            <i class="fas fa-heading"></i>
            Song Title
          </label>
          <input type="text" name="title" placeholder="Enter song title" required class="modern-input">
        </div>

        <div class="form-group">
          <label class="form-label">
            <i class="fas fa-user-music"></i>
            Artist Name
          </label>
          <input type="text" name="artist" placeholder="Enter artist name" required class="modern-input">
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">
          <i class="fas fa-compact-disc"></i>
          Select Album (optional)
        </label>
        <div class="select-wrapper">
          <select name="albumId" class="modern-select">
            <option value="">None (no album)</option>
            <% albums.forEach(album => { %>
              <option value="<%= album._id %>"><%= album.name %> - <%= album.artist %></option>
            <% }) %>
          </select>
          <i class="fas fa-chevron-down select-icon"></i>
        </div>
        <small style="color:var(--text-muted,#9aa);">Optional — leave blank to add the song without an album.</small>
      </div>

      <div class="upload-section">
        <div class="form-group upload-group">
          <label class="form-label">
            <i class="fas fa-file-audio"></i>
            Audio File
          </label>
          <div class="file-upload-wrapper">
            <input type="file" name="audio" accept="audio/*" required class="file-input" id="audioFile">
            <label for="audioFile" class="file-label">
              <i class="fas fa-cloud-upload-alt"></i>
              <span class="file-text">Choose audio file</span>
              <span class="file-name">No file chosen</span>
            </label>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">
            <i class="fas fa-language"></i>
            Language
          </label>
          <div class="select-wrapper">
            <select name="language" required class="modern-select">
              <option value="">Select language...</option>
              <option value="Hindi">Hindi</option>
              <option value="Punjabi">Punjabi</option>
              <option value="English">English</option>
              <option value="Other">Other</option>
            </select>
            <i class="fas fa-chevron-down select-icon"></i>
          </div>
        </div>
        <div class="form-group upload-group">
          <label class="form-label">
            <i class="fas fa-image"></i>
            Thumbnail Image
          </label>
          <div class="file-upload-wrapper">
            <input type="file" name="thumbnail" accept="image/*" required class="file-input" id="thumbnailFile">
            <label for="thumbnailFile" class="file-label">
              <i class="fas fa-cloud-upload-alt"></i>
              <span class="file-text">Choose thumbnail image</span>
              <span class="file-name">No file chosen</span>
            </label>
          </div>
        </div>
      </div>

      <div class="form-actions">
        <a href="/admin" class="btn-secondary">
          <i class="fas fa-arrow-left"></i>
          Back to Admin
        </a>
        <button type="submit" class="btn-primary">
          <i class="fas fa-plus-circle"></i>
          Add Song
        </button>
      </div>
    </form>
  </div>
</div>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 100%);
    min-height: 100vh;
  }

  .admin-modern-container {
    min-height: 100vh;
    padding: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .admin-modern-card {
    width: 100%;
    max-width: 700px;
    background: var(--bg-secondary, #12121f);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .card-header {
    padding: 20px;
    text-align: center;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .header-icon {
    width: 50px;
    height: 50px;
    margin: 0 auto 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 14px;
    font-size: 24px;
    color: white;
    box-shadow: 0 8px 24px rgba(102, 126, 234, 0.4);
  }

  .card-title {
    margin: 0 0 4px 0;
    font-size: 24px;
    font-weight: 800;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card-subtitle {
    margin: 0;
    font-size: 12px;
    color: var(--text-muted, #a0a0c0);
  }

  .modern-form {
    padding: 20px 28px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 10px;
  }

  .form-group {
    margin-bottom: 10px;
  }

  .form-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-secondary, #e0e0ff);
    margin-bottom: 5px;
  }

  .form-label i {
    color: #667eea;
    font-size: 13px;
  }

  .modern-input {
    width: 100%;
    padding: 9px 12px;
    background: var(--bg-tertiary, #1a1a2e);
    border: 2px solid rgba(255, 255, 255, 0.05);
    border-radius: 10px;
    color: var(--text-primary, #ffffff);
    font-size: 14px;
    font-family: inherit;
    transition: all 0.3s ease;
  }

  .modern-input:focus {
    outline: none;
    border-color: #667eea;
    background: var(--bg-secondary, #12121f);
    box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
  }

  .modern-input::placeholder {
    color: var(--text-dim, #707090);
  }

  .select-wrapper {
    position: relative;
  }

  .modern-select {
    width: 100%;
    padding: 9px 12px;
    padding-right: 36px;
    background: var(--bg-tertiary, #1a1a2e);
    border: 2px solid rgba(255, 255, 255, 0.05);
    border-radius: 10px;
    color: var(--text-primary, #ffffff);
    font-size: 14px;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.3s ease;
    appearance: none;
  }

  .modern-select:focus {
    outline: none;
    border-color: #667eea;
    background: var(--bg-secondary, #12121f);
    box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
  }

  .modern-select option {
    background: var(--bg-tertiary, #1a1a2e);
    color: var(--text-primary, #ffffff);
  }

  .select-icon {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted, #a0a0c0);
    pointer-events: none;
    font-size: 12px;
  }

  .upload-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 12px;
  }

  .file-upload-wrapper {
    position: relative;
  }

  .file-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .file-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 14px 10px;
    background: var(--bg-tertiary, #1a1a2e);
    border: 2px dashed rgba(102, 126, 234, 0.3);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    min-height: 90px;
  }

  .file-label:hover {
    border-color: #667eea;
    background: rgba(102, 126, 234, 0.05);
  }

  .file-input:focus + .file-label {
    border-color: #667eea;
    box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
  }

  .file-label i {
    font-size: 24px;
    color: #667eea;
  }

  .file-text {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-secondary, #e0e0ff);
  }

  .file-name {
    font-size: 10px;
    color: var(--text-muted, #a0a0c0);
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .form-actions {
    display: flex;
    gap: 12px;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .btn-primary,
  .btn-secondary {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 11px 20px;
    border: none;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    box-shadow: 0 4px 16px rgba(102, 126, 234, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(102, 126, 234, 0.5);
  }

  .btn-primary:active {
    transform: translateY(0);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-secondary, #e0e0ff);
    border: 2px solid rgba(255, 255, 255, 0.1);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 768px) {
    .card-header {
      padding: 24px 20px 20px;
    }

    .modern-form {
      padding: 24px 20px;
    }

    .form-row,
    .upload-section {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .form-actions {
      flex-direction: column;
    }

    .header-icon {
      width: 48px;
      height: 48px;
      font-size: 22px;
    }

    .card-title {
      font-size: 22px;
    }
  }
</style>

<script>
  // File input handling
  document.querySelectorAll('.file-input').forEach(input => {
    input.addEventListener('change', function() {
      const label = this.nextElementSibling;
      const fileName = label.querySelector('.file-name');
      
      if (this.files.length > 0) {
        fileName.textContent = this.files[0].name;
        label.style.borderColor = '#667eea';
        label.style.background = 'rgba(102, 126, 234, 0.05)';
      } else {
        fileName.textContent = 'No file chosen';
        label.style.borderColor = 'rgba(102, 126, 234, 0.3)';
        label.style.background = 'var(--bg-tertiary, #1a1a2e)';
      }
    });
  });
</script>
</body>
</html>