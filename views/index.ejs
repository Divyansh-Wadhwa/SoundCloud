<!-- Epic Hero Banner with Animated Background -->
<section class="hero-banner-epic">
  <div class="hero-animated-bg">
    <div class="gradient-orb orb-1"></div>
    <div class="gradient-orb orb-2"></div>
    <div class="gradient-orb orb-3"></div>
  </div>
  
  <div class="hero-content-wrapper">
    <!-- Interactive Music Visualizer -->
    <div class="music-visualizer">
      <div class="visualizer-bar" style="animation-delay: 0s;"></div>
      <div class="visualizer-bar" style="animation-delay: 0.1s;"></div>
      <div class="visualizer-bar" style="animation-delay: 0.2s;"></div>
      <div class="visualizer-bar" style="animation-delay: 0.3s;"></div>
      <div class="visualizer-bar" style="animation-delay: 0.4s;"></div>
      <div class="visualizer-bar" style="animation-delay: 0.2s;"></div>
      <div class="visualizer-bar" style="animation-delay: 0.1s;"></div>
      <div class="visualizer-bar" style="animation-delay: 0.3s;"></div>
      <div class="visualizer-bar" style="animation-delay: 0s;"></div>
    </div>
    
    <h1 class="typing-text">
      <span id="typed-text"></span>
      <span class="typing-cursor">|</span>
    </h1>
    
    <div class="hero-search-bar">
      <form action="/search" method="get" class="hero-search-form-new">
        <div class="search-input-wrapper">
          <i class="fas fa-search search-icon-new"></i>
          <input 
            type="text" 
            name="q" 
            placeholder="Search songs, artists, albums, playlists..." 
            class="search-input-new"
            autocomplete="off"
          >
        </div>
        <button type="submit" class="search-btn-new">
          <span>Search</span>
          <i class="fas fa-arrow-right"></i>
        </button>
      </form>
    </div>
  </div>
</section>

<!-- Quick Access Categories -->
<section class="quick-categories">
  <div class="container-fluid">
    <div class="categories-grid">
      <a href="/search?q=pop" class="category-card pop-card">
        <i class="fas fa-star"></i>
        <span>Pop</span>
      </a>
      <a href="/search?q=rock" class="category-card rock-card">
        <i class="fas fa-guitar"></i>
        <span>Rock</span>
      </a>
      <a href="/search?q=hip-hop" class="category-card hiphop-card">
        <i class="fas fa-microphone"></i>
        <span>Hip-Hop</span>
      </a>
      <a href="/search?q=electronic" class="category-card electronic-card">
        <i class="fas fa-volume-up"></i>
        <span>Electronic</span>
      </a>
      <a href="/search?q=jazz" class="category-card jazz-card">
        <i class="fas fa-music"></i>
        <span>Jazz</span>
      </a>
      <a href="/search?q=classical" class="category-card classical-card">
        <i class="fas fa-piano"></i>
        <span>Classical</span>
      </a>
    </div>
  </div>
</section>

<!-- Latest Tracks Section -->
<section class="content-section-new latest-tracks-section">
  <div class="container-fluid">
    <div class="section-header-new">
      <div class="section-title-wrapper">
        <h2 class="section-title-new">
          <i class="fas fa-bolt"></i>
          Latest Tracks
        </h2>
        <p class="section-subtitle">Fresh releases from artists around the globe</p>
      </div>
      <div class="lang-cards" style="display:flex;align-items:center;gap:12px;">
        <a href="/" class="lang-card <%= !selectedLang ? 'active' : '' %>">All</a>
        <a href="/?lang=Hindi" class="lang-card <%= selectedLang === 'Hindi' ? 'active' : '' %>">Hindi</a>
        <a href="/?lang=Punjabi" class="lang-card <%= selectedLang === 'Punjabi' ? 'active' : '' %>">Punjabi</a>
        <a href="/?lang=English" class="lang-card <%= selectedLang === 'English' ? 'active' : '' %>">English</a>
        <a href="/?lang=Other" class="lang-card <%= selectedLang === 'Other' ? 'active' : '' %>">Other</a>
        <% if(songs && songs.length > 12){ %>
          <a href="/search" class="view-all-btn-new">
            <span>View All</span>
            <i class="fas fa-arrow-right"></i>
          </a>
        <% } %>
      </div>

      <style>
        .lang-card {
          padding: 8px 12px;
          border-radius: 10px;
          background: rgba(255,255,255,0.03);
          color: var(--text-secondary);
          text-decoration: none;
          font-weight: 600;
          border: 1px solid transparent;
          transition: all 0.18s ease;
          display: inline-flex;
          align-items: center;
          gap: 8px;
        }
        .lang-card:hover { transform: translateY(-4px); background: rgba(255,255,255,0.06); color: var(--text-primary); }
        .lang-card.active { background: var(--primary-gradient); color: #fff; border-color: rgba(255,255,255,0.06); }
        .view-all-btn-new { margin-left: 8px; }
      </style>
    </div>
    
    <% if(songs && songs.length > 0){ %>
      <div class="tracks-grid-new">
        <% songs.slice(0, 12).forEach((song, idx) => { %>
          <div class="track-card-new" onclick="playSongInBottomBar('<%= song._id %>')" data-song-id="<%= song._id %>" data-animation-delay="<%= idx * 0.05 %>">
            <div class="track-cover-new">
              <img src="<%= song.thumbnail || '/images/default-cover.png' %>" alt="<%= song.title %>" loading="lazy">
              <div class="track-overlay">
                <button class="play-btn-new">
                  <i class="fas fa-play"></i>
                </button>
              </div>
              <% if(user){ %>
                <button class="fav-btn-new <%= user.favorites && user.favorites.some(f => f.toString() === song._id.toString()) ? 'active' : '' %>" onclick="event.stopPropagation(); toggleFavorite('<%= song._id %>', this)">
                  <i class="fas fa-heart"></i>
                </button>
              <% } %>
            </div>
            <div class="track-info-new">
              <h3 class="track-title-new"><%= song.title %></h3>
              <p class="track-artist-new"><%= song.artist %></p>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state-new">
        <div class="empty-icon-new">
          <i class="fas fa-music"></i>
        </div>
        <h3 class="empty-title-new">No Tracks Yet</h3>
        <p class="empty-text-new">Be the first to upload some amazing music!</p>
      </div>
    <% } %>
  </div>
</section>

<!-- Featured Albums Section -->
<section class="content-section-new albums-section">
  <div class="container-fluid">
    <div class="section-header-new">
      <div class="section-title-wrapper">
        <h2 class="section-title-new">
          <i class="fas fa-compact-disc"></i>
          Featured Albums
        </h2>
        <p class="section-subtitle">Curated collections for every mood</p>
      </div>
      <% if(albums && albums.length > 8){ %>
        <a href="/albums" class="view-all-btn-new">
          <span>View All</span>
          <i class="fas fa-arrow-right"></i>
        </a>
      <% } %>
    </div>
    
    <% if(albums && albums.length > 0){ %>
      <div class="albums-grid-new">
        <% albums.slice(0, 8).forEach((album, idx) => { %>
          <a href="/album/<%= album._id %>" class="album-card-new" data-animation-delay="<%= idx * 0.05 %>">
            <div class="album-cover-new">
              <% let albumCover = album.songs && album.songs.length > 0 ? album.songs[0].thumbnail : '/images/default-cover.png'; %>
              <img src="<%= albumCover %>" alt="<%= album.name %>" loading="lazy">
              <div class="album-overlay">
                <button class="album-play-btn">
                  <i class="fas fa-play"></i>
                </button>
              </div>
              <div class="album-tracks-badge">
                <i class="fas fa-list"></i>
                <%= album.songs ? album.songs.length : 0 %>
              </div>
            </div>
            <div class="album-info-new">
              <h3 class="album-title-new"><%= album.name %></h3>
              <p class="album-artist-new"><%= album.artist %></p>
            </div>
          </a>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state-new">
        <div class="empty-icon-new">
          <i class="fas fa-compact-disc"></i>
        </div>
        <h3 class="empty-title-new">No Albums Yet</h3>
        <p class="empty-text-new">Start creating your first album collection!</p>
      </div>
    <% } %>
  </div>
</section>

<style>
/* ========================================
   EPIC INDEX PAGE REDESIGN
======================================== */

/* Hero Banner */
.hero-banner-epic {
  position: relative;
  min-height: 600px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120px 40px 80px;
  overflow: hidden;
  background: linear-gradient(135deg, #0a0a14 0%, #1a1a2e 100%);
}

.hero-animated-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

.gradient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.4;
  animation: float 20s infinite ease-in-out;
}

.orb-1 {
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, #667eea 0%, transparent 70%);
  top: -10%;
  left: -10%;
  animation-delay: 0s;
}

.orb-2 {
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, #f093fb 0%, transparent 70%);
  top: 20%;
  right: -5%;
  animation-delay: 7s;
}

.orb-3 {
  width: 450px;
  height: 450px;
  background: radial-gradient(circle, #4facfe 0%, transparent 70%);
  bottom: -10%;
  left: 50%;
  animation-delay: 14s;
}

@keyframes float {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(30px, -30px) scale(1.1); }
  66% { transform: translate(-20px, 20px) scale(0.9); }
}

.hero-content-wrapper {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 900px;
  animation: fadeInUp 0.8s ease-out;
}

/* Music Visualizer Animation */
.music-visualizer {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 8px;
  height: 100px;
  margin-bottom: 32px;
}

.visualizer-bar {
  width: 8px;
  min-height: 20px;
  background: var(--fire-gradient);
  border-radius: 4px;
  animation: visualizerPulse 1.2s ease-in-out infinite;
  box-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
  transform-origin: bottom;
}

@keyframes visualizerPulse {
  0%, 100% {
    height: 20px;
    opacity: 0.6;
  }
  25% {
    height: 60px;
    opacity: 1;
  }
  50% {
    height: 90px;
    opacity: 0.8;
  }
  75% {
    height: 40px;
    opacity: 1;
  }
}

/* Typing Effect */
.typing-text {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 24px;
  min-height: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

#typed-text {
  background: var(--fire-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.typing-cursor {
  color: var(--accent-1);
  animation: blink 0.7s infinite;
  font-weight: 300;
}

@keyframes blink {
  0%, 49% { opacity: 1; }
  50%, 100% { opacity: 0; }
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 20px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(102, 126, 234, 0.3);
  border-radius: 50px;
  color: var(--accent-1);
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 24px;
  backdrop-filter: blur(10px);
}

.hero-badge i {
