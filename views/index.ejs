<script>
// Typing Effect with Multiple Messages
document.addEventListener('DOMContentLoaded', () => {
  // Apply animation-delay attributes to cards
  document.querySelectorAll('.track-card-new[data-animation-delay]').forEach(function(el) {
    el.style.animationDelay = el.getAttribute('data-animation-delay') + 's';
  });
  document.querySelectorAll('.album-card-new[data-animation-delay]').forEach(function(el) {
    el.style.animationDelay = el.getAttribute('data-animation-delay') + 's';
  });
  const messages = [
    "Welcome to SoundCloud",
    "Explore Your Favourite Music",
    "Discover New Artists",
    "Stream Unlimited Tracks",
    "Your Music, Your Way"
  ];
  
  const typedTextElement = document.getElementById('typed-text');
  let messageIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  
  function typeText() {
    const currentMessage = messages[messageIndex];
    
    if (!isDeleting) {
      // Typing
      typedTextElement.textContent = currentMessage.substring(0, charIndex + 1);
      charIndex++;
      
      if (charIndex === currentMessage.length) {
        // Pause before deleting
        setTimeout(() => {
          isDeleting = true;
          typeText();
        }, 2000);
        return;
      }
      setTimeout(typeText, 100);
    } else {
      // Deleting
      typedTextElement.textContent = currentMessage.substring(0, charIndex - 1);
      charIndex--;
      
      if (charIndex === 0) {
        isDeleting = false;
        messageIndex = (messageIndex + 1) % messages.length;
        setTimeout(typeText, 500);
        return;
      }
      setTimeout(typeText, 50);
    }
  }
  
  setTimeout(typeText, 500);
});
</script>
