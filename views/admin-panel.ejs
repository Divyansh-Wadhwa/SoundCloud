<script>
  // Add to Album Modal
  function showAddToAlbumModal(songId, songTitle) {
    const modal = document.getElementById('addToAlbumModal');
    document.getElementById('modalSongTitle').textContent = songTitle;
    document.getElementById('modalSongId').value = songId;
    modal.classList.add('active');
  }

  function closeAddToAlbumModal() {
    const modal = document.getElementById('addToAlbumModal');
    modal.classList.remove('active');
  }

  function addSongToAlbum(albumId) {
    const songId = document.getElementById('modalSongId').value;
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = `/admin/songs/${songId}/add-to-album/${albumId}`;
    document.body.appendChild(form);
    form.submit();
  }

  // Close modal on background click
  document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('addToAlbumModal');
    if (modal) {
      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          closeAddToAlbumModal();
        }
      });
    }
  });
</script>

