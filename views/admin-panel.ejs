<script>
  (function(){
    const input = document.getElementById('adminSongSearch');
    if (!input) return;
    const cards = () => Array.from(document.querySelectorAll('.song-card-admin'));
    function normalize(s){ return (s||'').toLowerCase(); }
    input.addEventListener('input', function(){
      const q = normalize(this.value.trim());
      if (!q) { cards().forEach(c => c.style.display = 'flex'); return; }
      cards().forEach(card => {
        const title = normalize(card.querySelector('.song-card-title')?.textContent);
        const artist = normalize(card.querySelector('.song-card-artist')?.textContent);
        const match = title.includes(q) || artist.includes(q);
        card.style.display = match ? 'flex' : 'none';
      });
    });
  })();
</script>

<script>
  // Show songs grid only when admin clicks "All Songs"
  (function(){
    const btn = document.getElementById('showAllSongsBtn');
    const grid = document.getElementById('adminSongsGrid');
    if (!btn || !grid) return;
    btn.addEventListener('click', function(){
      grid.classList.remove('collapsed');
      btn.style.display = 'none';
      const s = document.getElementById('adminSongSearch'); if (s) s.focus();
      // Show title and back button
      const titleEl = document.getElementById('adminSongsTitle');
      const backBtn = document.getElementById('backFromSongsBtn');
      if (titleEl) { titleEl.textContent = 'All songs'; titleEl.style.display = 'block'; }
      if (backBtn) backBtn.style.display = 'inline-flex';
      // hide any site search-title elements if present
      const siteSearchTitle = document.querySelector('.search-title'); if (siteSearchTitle) siteSearchTitle.style.display = 'none';
    });

    // Back button: collapse grid and restore state
    const backBtn = document.getElementById('backFromSongsBtn');
    if (backBtn) {
      backBtn.addEventListener('click', function(){
        grid.classList.add('collapsed');
        btn.style.display = 'inline-flex';
        const titleEl = document.getElementById('adminSongsTitle'); if (titleEl) { titleEl.textContent = ''; titleEl.style.display = 'none'; }
        backBtn.style.display = 'none';
        // show any site search-title elements again
        const siteSearchTitle = document.querySelector('.search-title'); if (siteSearchTitle) siteSearchTitle.style.display = '';
      });
    }
  })();
</script>

<script>
  // Custom Modal System (same as layout.ejs)
  window.showModal = function(options) {
    const modalHtml = `
      <div class="modal-overlay-custom" id="customModalOverlay">
        <div class="modal-container-custom">
          <div class="modal-header-custom">
            <h3 class="modal-title-custom">${options.title || 'Confirm'}</h3>
          </div>
          <div class="modal-body-custom">
            <p class="modal-message-custom">${options.message || ''}</p>
          </div>
          <div class="modal-footer-custom">
            <button class="modal-btn-custom modal-btn-cancel" onclick="window.closeModal()">Cancel</button>
            <button class="modal-btn-custom modal-btn-confirm ${options.danger ? 'danger' : ''}" onclick="window.handleModalConfirm()">${options.confirmText || 'Confirm'}</button>
          </div>
        </div>
      </div>
    `;
    
    document.body.insertAdjacentHTML('beforeend', modalHtml);
    
    window.modalConfirmCallback = options.onConfirm;
    
    setTimeout(() => {
      document.getElementById('customModalOverlay').classList.add('active');
    }, 10);
  };

  window.closeModal = function() {
    const overlay = document.getElementById('customModalOverlay');
    if (overlay) {
      overlay.classList.remove('active');
      setTimeout(() => overlay.remove(), 300);
    }
  };

  window.handleModalConfirm = function() {
    if (window.modalConfirmCallback) {
      window.modalConfirmCallback();
    }
    window.closeModal();
  };

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      window.closeModal();
    }
  });
</script>

