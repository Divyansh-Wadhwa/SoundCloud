<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Admin Panel' %> - SoundCloud</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

<div class="admin-wrapper">
  <div class="admin-hero">
    <div class="hero-content">
      <div class="hero-icon">
        <i class="fas fa-shield-alt"></i>
      </div>
      <div class="hero-text">
        <h1 class="hero-title">Admin Dashboard</h1>
        <p class="hero-subtitle">Manage your music library and users</p>
      </div>
    </div>
    <div class="hero-actions">
      <a class="action-btn btn-primary" href="/">
        <i class="fas fa-home"></i>
        <span>Home</span>
      </a>
      <a class="action-btn btn-primary" href="/admin/albums/create">
        <i class="fas fa-compact-disc"></i>
        <span>New Album</span>
      </a>
      <a class="action-btn btn-primary" href="/admin/songs/create">
        <i class="fas fa-music"></i>
        <span>New Song</span>
      </a>
      <a class="action-btn btn-ghost" href="/logout">
        <i class="fas fa-sign-out-alt"></i>
        <span>Logout</span>
      </a>
    </div>
  </div>

  <div class="admin-layout">
    <section class="main-panel">
      <!-- All Songs Section -->
      <div class="panel-header">
        <i class="fas fa-music"></i>
        <h2>Songs</h2>
        <span class="count-badge"><%= allSongs.length %></span>
        <button id="showAllSongsBtn" class="action-btn btn-ghost" style="margin-left:12px;">All Songs</button>
      </div>

      <div class="panel-actions" style="margin:12px 0 18px; display:flex; align-items:center; gap:12px;">
        <input id="adminSongSearch" class="modern-input" type="search" placeholder="Search songs by title or artist...">
        <div class="songs-toolbar" style="margin-left:auto; display:flex; gap:8px; align-items:center;">
          <h3 id="adminSongsTitle" style="color:#e8e8f0; margin:0; font-size:16px; display:none;"></h3>
          <button id="backFromSongsBtn" class="action-btn btn-ghost" style="display:none;">Back</button>
        </div>
      </div>

      <div class="songs-grid collapsed" id="adminSongsGrid">
        <% allSongs.forEach(song => { %>
          <div class="song-card-admin">
            <div class="song-card-thumbnail">
              <img src="<%= song.thumbnail || '/images/default-cover.png' %>" alt="<%= song.title %>">
            </div>
            <div class="song-card-info">
              <div class="song-card-title"><%= song.title %></div>
              <div class="song-card-artist"><%= song.artist %></div>
            </div>
            <div class="song-card-actions">
              <button class="song-action-btn add-to-album-btn" onclick="showAddToAlbumModal('<%= song._id %>', '<%= song.title %>')" title="Add to Album">
                <i class="fas fa-plus"></i>
              </button>
              <a href="/admin/songs/edit/<%= song._id %>" class="song-action-btn edit-btn" title="Edit song">
                <i class="fas fa-edit"></i>
              </a>
              <form action="/admin/songs/delete/<%= song._id %>" method="POST" style="flex: 1;">
                <button class="song-action-btn delete-btn" type="submit" title="Delete song">
                  <i class="fas fa-trash-alt"></i>
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Albums Section -->
      <div class="panel-header" style="margin-top: 40px;">
        <i class="fas fa-compact-disc"></i>
        <h2>Albums Collection</h2>
        <span class="count-badge"><%= albums.length %></span>
      </div>
      
      <div class="album-grid">
        <% albums.forEach(album => { %>
          <article class="album-modern-card">
            <div class="album-card-header">
              <div class="album-info">
                <h3 class="album-name"><%= album.name %></h3>
                <p class="album-artist-name"><i class="fas fa-user"></i> <%= album.artist %></p>
              </div>
              <form action="/admin/albums/delete/<%= album._id %>" method="POST">
                <button class="delete-album-btn" type="button" onclick="window.showModal({title: 'Delete Album', message: 'Are you sure you want to delete this album and all its songs? This action cannot be undone.', danger: true, confirmText: 'Delete', onConfirm: () => { this.closest('form').submit(); }});">
                  <i class="fas fa-trash-alt"></i>
                </button>
              </form>
            </div>

            <div class="album-content">
              <details class="songs-details">
                <summary class="songs-summary">
                  <i class="fas fa-music"></i>
                  <span><%= album.songs.length %> Songs</span>
                  <i class="fas fa-chevron-down chevron-icon"></i>
                </summary>
                
                <div class="songs-container">
                  <% album.songs.forEach(song => { %>
                    <div class="song-item">
                      <div class="song-info">
                        <i class="fas fa-play-circle song-icon"></i>
                        <div class="song-details">
                          <span class="song-name"><%= song.title %></span>
                          <span class="song-artist-mini"><%= song.artist %></span>
                        </div>
                      </div>
                      <div class="song-buttons">
                        <form action="/admin/albums/<%= album._id %>/remove/<%= song._id %>" method="POST" style="display:inline;">
                          <button class="mini-btn btn-remove" type="submit" title="Remove from album">
                            <i class="fas fa-minus-circle"></i>
                          </button>
                        </form>
                        <form action="/admin/songs/delete/<%= song._id %>" method="POST" style="display:inline;">
                          <button class="mini-btn btn-delete" type="submit" title="Delete song">
                            <i class="fas fa-trash"></i>
                          </button>
                        </form>
                      </div>
                    </div>
                  <% }) %>

                  <form class="add-song-form" action="/admin/albums/<%= album._id %>/add-song" method="POST" enctype="multipart/form-data">
                    <div class="form-group-inline">
                      <input type="text" name="title" placeholder="Song Title" required class="compact-input">
                      <input type="text" name="artist" placeholder="Artist" required class="compact-input">
                    </div>
                    <div class="file-uploads-row">
                      <label class="file-upload-mini">
                        <input type="file" name="audio" accept="audio/*" required>
                        <i class="fas fa-file-audio"></i>
                        <span>Audio</span>
                      </label>
                      <label class="file-upload-mini">
                        <input type="file" name="thumbnail" accept="image/*" required>
                        <i class="fas fa-image"></i>
                        <span>Cover</span>
                      </label>
                      <button class="compact-submit-btn" type="submit">
                        <i class="fas fa-plus"></i>
                        Add
                      </button>
                    </div>
                  </form>
                </div>
              </details>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <aside class="side-panel">
      <div class="panel-card users-card">
        <div class="panel-header">
          <i class="fas fa-users"></i>
          <h2>Users</h2>
          <span class="count-badge"><%= users.length %></span>
        </div>
        
        <div class="users-scroll">
          <% users.forEach(user => { %>
            <div class="user-item">
              <div class="user-avatar">
                <img src="https://api.dicebear.com/7.x/bottts-neutral/svg?seed=<%= user.username %>" alt="<%= user.username %>">
              </div>
              <div class="user-info">
                <div class="user-username"><%= user.username %></div>
                <div class="user-email-text"><%= user.email %></div>
              </div>
              <div class="user-stats">
                <i class="fas fa-list"></i>
                <span><%= user.playlists.length %></span>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="panel-card stats-card">
        <div class="panel-header">
          <i class="fas fa-chart-line"></i>
          <h2>Quick Stats</h2>
        </div>
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-icon">
              <i class="fas fa-compact-disc"></i>
            </div>
            <div class="stat-details">
              <div class="stat-value"><%= albums.length %></div>
              <div class="stat-label">Albums</div>
            </div>
          </div>
          <div class="stat-item">
            <div class="stat-icon">
              <i class="fas fa-users"></i>
            </div>
            <div class="stat-details">
              <div class="stat-value"><%= users.length %></div>
              <div class="stat-label">Users</div>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>
</div>

<!-- Add to Album Modal -->
<div id="addToAlbumModal" class="album-selection-modal">
  <div class="album-selection-content">
    <div class="album-selection-header">
      <div class="album-selection-title">Add "<span id="modalSongTitle"></span>" to Album</div>
      <div class="album-selection-subtitle">Select an album to add this song</div>
    </div>
    
    <input type="hidden" id="modalSongId" value="">
    
    <div class="album-list">
      <% albums.forEach(album => { %>
        <div class="album-option" onclick="addSongToAlbum('<%= album._id %>')">
          <div class="album-option-icon">
            <i class="fas fa-compact-disc"></i>
          </div>
          <div class="album-option-info">
            <div class="album-option-name"><%= album.name %></div>
            <div class="album-option-artist"><%= album.artist %> • <%= album.songs.length %> songs</div>
          </div>
        </div>
      <% }) %>
    </div>
    
    <button class="modal-close-btn" onclick="closeAddToAlbumModal()">Cancel</button>
  </div>
</div>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 100%);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  /* Search input styling (minimal, targeted) */
  #adminSongSearch {
    max-width: 560px;
    width: 100%;
    padding: 10px 14px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.02);
    color: #e8e8f0;
    font-size: 14px;
    transition: box-shadow .12s ease, border-color .12s ease, background .12s ease;
  }
  #adminSongSearch::placeholder { color: rgba(232,232,240,0.45); }
  #adminSongSearch:focus {
    outline: none;
    border-color: #667eea;
    background: rgba(28,28,40,0.6);
    box-shadow: 0 8px 30px rgba(102,126,234,0.06);
  }

  .admin-wrapper {
    min-height: 100vh;
    padding: 20px;
  }


  /* Hero Section */
  .admin-hero {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%);
    border: 1px solid rgba(102, 126, 234, 0.2);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
    backdrop-filter: blur(10px);
  }

  .hero-content {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .hero-icon {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    color: white;
    box-shadow: 0 8px 24px rgba(102, 126, 234, 0.4);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .hero-title {
    font-size: 28px;
    font-weight: 800;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 14px;
    color: #a0a0c0;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(102, 126, 234, 0.5);
  }

  .btn-ghost {
    background: rgba(255, 255, 255, 0.05);
    color: #e0e0ff;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* Layout */
  .admin-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 20px;
  }

  /* Panel Headers */
  .panel-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .panel-header i {
    font-size: 20px;
    color: #667eea;
  }

  .panel-header h2 {
    font-size: 18px;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    flex: 1;
  }

  .count-badge {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 700;
  }

  /* Main Panel - Albums */
  .main-panel {
    display: flex;
    flex-direction: column;
  }

  .album-grid {
    display: grid;
    gap: 16px;
  }

  .album-modern-card {
    background: rgba(18, 18, 31, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    padding: 18px;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
  }

  .album-modern-card:hover {
    transform: translateY(-2px);
    border-color: rgba(102, 126, 234, 0.3);
    box-shadow: 0 12px 32px rgba(102, 126, 234, 0.15);
  }

  .album-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 12px;
  }

  .album-info {
    flex: 1;
  }

  .album-name {
    font-size: 18px;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 6px 0;
  }

  .album-artist-name {
    font-size: 13px;
    color: #a0a0c0;
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 0;
  }

  .album-artist-name i {
    font-size: 11px;
  }

  .delete-album-btn {
    width: 36px;
    height: 36px;
    background: rgba(255, 77, 79, 0.1);
    border: 1px solid rgba(255, 77, 79, 0.2);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ff6b6b;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .delete-album-btn:hover {
    background: rgba(255, 77, 79, 0.2);
    border-color: rgba(255, 77, 79, 0.4);
    transform: scale(1.05);
  }

  /* Songs Details */
  .songs-details {
    margin-top: 10px;
  }

  .songs-summary {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: rgba(102, 126, 234, 0.05);
    border: 1px solid rgba(102, 126, 234, 0.15);
    border-radius: 10px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    color: #667eea;
    transition: all 0.3s ease;
    list-style: none;
    user-select: none;
  }

  .songs-summary::-webkit-details-marker {
    display: none;
  }

  .songs-summary span {
    flex: 1;
  }

  .chevron-icon {
    font-size: 12px;
    transition: transform 0.3s ease;
  }

  .songs-details[open] .chevron-icon {
    transform: rotate(180deg);
  }

  .songs-summary:hover {
    background: rgba(102, 126, 234, 0.1);
    border-color: rgba(102, 126, 234, 0.25);
  }

  .songs-container {
    margin-top: 12px;
    padding: 12px;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .song-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    transition: all 0.3s ease;
  }

  .song-item:last-of-type {
    border-bottom: none;
  }

  .song-item:hover {
    background: rgba(102, 126, 234, 0.05);
    border-radius: 8px;
  }

  .song-info {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
  }

  .song-icon {
    font-size: 16px;
    color: #667eea;
  }

  .song-details {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .song-name {
    font-size: 14px;
    font-weight: 600;
    color: #ffffff;
  }

  .song-artist-mini {
    font-size: 12px;
    color: #a0a0c0;
  }

  .song-buttons {
    display: flex;
    gap: 6px;
  }

  .mini-btn {
    width: 30px;
    height: 30px;
    border-radius: 6px;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 12px;
  }

  .btn-remove {
    background: rgba(255, 193, 7, 0.1);
    color: #ffc107;
    border: 1px solid rgba(255, 193, 7, 0.2);
  }

  .btn-remove:hover {
    background: rgba(255, 193, 7, 0.2);
    transform: scale(1.1);
  }

  .btn-delete {
    background: rgba(255, 77, 79, 0.1);
    color: #ff6b6b;
    border: 1px solid rgba(255, 77, 79, 0.2);
  }

  .btn-delete:hover {
    background: rgba(255, 77, 79, 0.2);
    transform: scale(1.1);
  }

  /* Add Song Form */
  .add-song-form {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .form-group-inline {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .compact-input {
    padding: 8px 12px;
    background: rgba(26, 26, 46, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    color: #ffffff;
    font-size: 13px;
    font-family: inherit;
    transition: all 0.3s ease;
  }

  .compact-input:focus {
    outline: none;
    border-color: #667eea;
    background: rgba(26, 26, 46, 1);
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  }

  .file-uploads-row {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 8px;
  }

  .file-upload-mini {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 10px;
    background: rgba(102, 126, 234, 0.05);
    border: 1px dashed rgba(102, 126, 234, 0.3);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 11px;
    color: #a0a0c0;
  }

  .file-upload-mini input[type="file"] {
    display: none;
  }

  /* Admin songs grid: show two rows by default when collapsed */
  #adminSongsGrid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
    align-items: start;
    grid-auto-rows: auto;
  }

  #adminSongsGrid.collapsed {
    max-height: 560px; /* show approx two rows */
    overflow: hidden;
    position: relative;
  }

  /* Optional visual fade at bottom when collapsed */
  #adminSongsGrid.collapsed::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 40px;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(10,10,15,0.9) 90%);
  }

  

  .file-upload-mini i {
    font-size: 18px;
    color: #667eea;
  }

  .file-upload-mini:hover {
    background: rgba(102, 126, 234, 0.1);
    border-color: #667eea;
  }

  .compact-submit-btn {
    padding: 10px 16px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    border-radius: 8px;
    color: white;
    font-weight: 600;
    font-size: 13px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    transition: all 0.3s ease;
  }

  .compact-submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(102, 126, 234, 0.4);
  }

  /* Side Panel */
  .side-panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .panel-card {
    background: rgba(18, 18, 31, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    padding: 18px;
    backdrop-filter: blur(10px);
  }

  /* Users Card */
  .users-scroll {
    max-height: 450px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .users-scroll::-webkit-scrollbar {
    width: 6px;
  }

  .users-scroll::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 10px;
  }

  .users-scroll::-webkit-scrollbar-thumb {
    background: rgba(102, 126, 234, 0.3);
    border-radius: 10px;
  }

  .users-scroll::-webkit-scrollbar-thumb:hover {
    background: rgba(102, 126, 234, 0.5);
  }

  .user-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 10px;
    transition: all 0.3s ease;
  }

  .user-item:hover {
