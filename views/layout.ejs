<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SoundCloud</title>
  <!-- Google Font for a modern UI similar to SoundCloud -->
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap" rel="stylesheet">
  <!-- Font Awesome for aesthetic icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/cards-redesign.css">
    <% if (typeof admin !== 'undefined' && admin) { %>
      <link rel="stylesheet" href="/css/admin.css">
    <% } %>
</head>
<body class="<%= (user && !admin) ? 'with-player' : '' %>">
  <!-- Top Navbar -->
  <nav class="top-navbar" id="topNavbar">
    <!-- Brand Section -->
    <a href="/" class="nav-brand">
      <img src="/images/logo.svg" alt="SoundCloud Logo" class="brand-icon">
      <span class="brand-text">SoundCloud</span>
    </a>

    <!-- Main Navigation Links -->
    <div class="nav-menu">
      <a href="/" class="menu-link">
        <i class="fas fa-house"></i>
        <span>Home</span>
      </a>

      <% if(user && !admin){ %>
        <a href="/playlists" class="menu-link">
          <i class="fas fa-list"></i>
          <span>Playlists</span>
        </a>
        <a href="/favorites" class="menu-link">
          <i class="fas fa-heart"></i>
          <span>Favorites</span>
        </a>
      <% } %>

    </div>

    <!-- Right Actions -->
    <div class="nav-actions">
      <% if(user){ %>
        <!-- User Avatar Dropdown -->
        <div class="user-dropdown">
          <button class="user-avatar-btn" id="userAvatarBtn">
            <img src="https://api.dicebear.com/7.x/bottts-neutral/svg?seed=<%= user.username %>" alt="<%= user.username %>" class="user-avatar-img">
          </button>
          <div class="user-dropdown-menu" id="userDropdownMenu">
            <div class="dropdown-header">
              <div class="dropdown-avatar">
                <img src="https://api.dicebear.com/7.x/bottts-neutral/svg?seed=<%= user.username %>" alt="<%= user.username %>" class="user-avatar-img">
              </div>
              <div class="dropdown-user-info">
                <span class="dropdown-username"><%= user.username %></span>
                <span class="dropdown-email"><%= user.email %></span>
              </div>
            </div>
            <div class="dropdown-divider"></div>
            <a href="<%= admin ? '/admin' : '/dashboard' %>" class="dropdown-item">
              <i class="fas fa-home"></i>
              <span>Dashboard</span>
            </a>
            <% if(!admin){ %>
            <a href="/playlists" class="dropdown-item">
              <i class="fas fa-list"></i>
              <span>My Playlists</span>
            </a>
            <% } %>
            <div class="dropdown-divider"></div>
            <a href="/logout" class="dropdown-item logout-item">
              <i class="fas fa-power-off"></i>
              <span>Logout</span>
            </a>
          </div>
        </div>
      <% } else { %>
        <a href="/login" class="action-btn login-btn">
          <i class="fas fa-sign-in-alt"></i>
          <span>Login</span>
        </a>
        <a href="/register" class="action-btn register-btn">
          <i class="fas fa-user-plus"></i>
          <span>Sign Up</span>
        </a>
      <% } %>
    </div>
  </nav>

  <div class="app">
    <!-- Main content -->
    <main class="main-content">
      <%- body %> <!-- Songs and other content will go here -->
    </main>
  </div>


  <script src="/js/script.js"></script>
  <script>
      // Robust: Save global audio state to localStorage before navigating to player page
      function attachMusicBarHandler() {
        const bar = document.getElementById('globalBottomPlayer');
        if (!bar) {
          console.warn('[music bar] globalBottomPlayer not found! Retrying in 500ms...');
          setTimeout(attachMusicBarHandler, 500);
          return;
        }
        if (bar._handlerAttached) return; // Prevent double-attach
        bar._handlerAttached = true;
        bar.addEventListener('click', function(e) {
          const audio = document.getElementById('globalAudio');
          // Ensure queue and index are available globally
          let songId = null;
          if (window.queue && typeof window.index !== 'undefined' && window.queue[window.index] && window.queue[window.index]._id) {
            songId = window.queue[window.index]._id;
          } else if (typeof queue !== 'undefined' && typeof index !== 'undefined' && queue[index] && queue[index]._id) {
            songId = queue[index]._id;
          }
          if(audio && songId) {
            console.log('[music bar] Saving resume data:', { songId, currentTime: audio.currentTime, paused: audio.paused });
            localStorage.setItem('player_resume', JSON.stringify({
              songId: songId,
              currentTime: audio.currentTime,
              paused: audio.paused
            }));
            setTimeout(function() {
              console.log('[music bar] Navigating to player page for', songId);
              window.location.href = '/player/' + songId;
            }, 500); // 500ms delay to ensure localStorage is written
          } else {
            console.warn('[music bar] Missing audio or songId', {audio, songId, queue, index});
          }
        });
        console.log('[music bar] Click handler attached');
      }
      attachMusicBarHandler();
  // AJAX navigation for player links
  document.addEventListener('click', function(e) {
    const link = e.target.closest('a');
    if (link && link.getAttribute('href') && link.getAttribute('href').startsWith('/player/')) {
      e.preventDefault();
      const url = link.getAttribute('href');
      fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(res => res.text())
        .then(html => {
          // Extract only the main content from the response
          const temp = document.createElement('div');
          temp.innerHTML = html;
          const newContent = temp.querySelector('.main-content');
          if (newContent) {
            document.querySelector('.main-content').innerHTML = newContent.innerHTML;
            window.history.pushState({}, '', url);
            window.scrollTo(0, 0);
          } else {
            // fallback to full reload if structure not found
            window.location.href = url;
          }
        })
        .catch(() => window.location.href = url);
    }
  });
  // Handle browser navigation (back/forward)
  window.addEventListener('popstate', function() {
    fetch(window.location.pathname, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(res => res.text())
      .then(html => {
        const temp = document.createElement('div');
        temp.innerHTML = html;
        const newContent = temp.querySelector('.main-content');
        if (newContent) {
          document.querySelector('.main-content').innerHTML = newContent.innerHTML;
        } else {
          window.location.reload();
        }
      })
      .catch(() => window.location.reload());
  });
  </script>

  <% if (user && !admin) { %>
    <!-- Global audio player (persistent across pages for regular users only) -->
    <audio id="globalAudio" preload="metadata" style="display:none"></audio>

    <div class="bottom-player hidden" id="globalBottomPlayer" aria-hidden="true" style="cursor: pointer;" title="Click to open full player">
      <div class="bp-left">
        <img id="bp-cover" src="/images/default-cover.png" alt="cover" />
        <div class="bp-meta">
          <div id="bp-title">No track</div>
          <div id="bp-artist">—</div>
        </div>
      </div>
      <div class="bp-center">
        <div class="bp-controls">
          <button id="bp-prev" class="bp-btn">⏮</button>
          <button id="bp-play" class="bp-btn bp-play">▶</button>
          <button id="bp-next" class="bp-btn">⏭</button>
        </div>
        <div class="bp-progress-wrap">
          <span id="bp-curtime">0:00</span>
          <input type="range" id="bp-slider" min="0" max="100" value="0" step="0.1" style="vertical-align: middle;">
          <span id="bp-duration">0:00</span>
        </div>
      </div>
      <div class="bp-right">
        <button id="bp-favorite" class="bp-btn bp-favorite" title="Add to favorites">
          <i class="fas fa-heart"></i>
        </button>
        <button id="bp-collapse" class="bp-btn bp-collapse" title="Collapse player">
          <i class="fas fa-chevron-down"></i>
        </button>
      </div>
    </div>

    <!-- Collapsed Disc Player -->
    <div class="disc-player hidden" id="discPlayer" title="Click to expand player">
      <div class="disc-rotating">
        <i class="fas fa-compact-disc"></i>
      </div>
    </div>

    <script>
      // Global player state and functions (available on window)
      (function(){
        const audio = document.getElementById('globalAudio');
        const playBtn = document.getElementById('bp-play');
        const prevBtn = document.getElementById('bp-prev');
        const nextBtn = document.getElementById('bp-next');
        const curTimeEl = document.getElementById('bp-curtime');
        const durEl = document.getElementById('bp-duration');
        const fill = document.getElementById('bp-fill');
        const titleEl = document.getElementById('bp-title');
        const artistEl = document.getElementById('bp-artist');
        const coverEl = document.getElementById('bp-cover');
        const bottomPlayer = document.getElementById('globalBottomPlayer');

        let queue = [];
        let index = 0;
        let currentSongId = null;

        function fmt(s){ if(!isFinite(s)) return '0:00'; const m=Math.floor(s/60); const sec=Math.floor(s%60).toString().padStart(2,'0'); return `${m}:${sec}`; }

        function setQueue(q){ queue = Array.isArray(q) ? q : []; console.log('[global player] setQueue length=', queue.length); }
        
        function loadTrack(i){
          if(!queue.length) return; 
          index = Math.max(0, Math.min(i, queue.length-1)); 
          const t = queue[index];
          console.log('[global player] loadTrack idx=', index, 'file=', t && t.file);
          currentSongId = t._id || null;
          audio.src = t.file || '';
          titleEl.textContent = t.title || 'Unknown'; 
          artistEl.textContent = t.artist || '';
          coverEl.src = t.thumbnail || '/images/default-cover.png';
          
          // Update favorite button state
          updateFavoriteButton();
          
          // quick HEAD check to surface 404/403 issues in browser console
          try {
            if (audio.src) {
              fetch(audio.src, { method: 'HEAD' }).then(r => {
                console.log('[global player] HEAD', audio.src, 'status=', r.status);
              }).catch(err => console.warn('[global player] HEAD failed for', audio.src, err));
            }
          } catch (e) { console.warn('[global player] HEAD check error', e); }
          audio.load();
        }
        
        function play(){
          console.log('[global player] play() called, src=', audio.currentSrc || audio.src);
          
          // Show music bar when playing
          if (bottomPlayer && bottomPlayer.classList.contains('hidden')) {
            bottomPlayer.classList.remove('hidden');
            bottomPlayer.setAttribute('aria-hidden', 'false');
          }
          
          const p = audio.play();
          if(p && p.then) p.then(()=>{ playBtn.textContent='⏸'; console.log('[global player] play started'); }).catch((err)=>{ playBtn.textContent='▶'; console.warn('[global player] play() rejected', err); });
        }
        
        function pause(){ audio.pause(); playBtn.textContent='▶'; }
        function togglePlay(){ if(!audio.src && queue.length) loadTrack(0); if(audio.paused) play(); else pause(); }

        playBtn.addEventListener('click', togglePlay);
        prevBtn.addEventListener('click', ()=>{ if(index>0){ loadTrack(index-1); play(); } });
        nextBtn.addEventListener('click', ()=>{ if(index<queue.length-1){ loadTrack(index+1); play(); } });

        audio.addEventListener('timeupdate', ()=>{
          curTimeEl.textContent = fmt(audio.currentTime);
          durEl.textContent = fmt(audio.duration);
          const pct = (audio.currentTime/audio.duration)*100 || 0;
          if (fill) fill.style.width = pct+'%';
          // Update slider
          const slider = document.getElementById('bp-slider');
          if (slider && audio.duration) {
            const pctVal = (audio.currentTime / audio.duration) * 100;
            slider.value = pctVal;
            // set CSS variable for fill percent
            slider.style.setProperty('--pct', pctVal + '%');
          }
        });

        // Slider seeking
        const slider = document.getElementById('bp-slider');
        if (slider) {
          slider.addEventListener('input', function(e) {
            if (audio.duration) {
              const pct = parseFloat(slider.value) || 0;
              slider.style.setProperty('--pct', pct + '%');
              audio.currentTime = (pct / 100) * audio.duration;
            }
          });
        }
        audio.addEventListener('ended', ()=>{ if(index<queue.length-1){ loadTrack(index+1); play(); } else { playBtn.textContent='▶'; } });
        audio.addEventListener('error', (ev)=>{ console.error('[global player] error', ev, 'currentSrc=', audio.currentSrc || audio.src); titleEl.textContent='Error loading'; artistEl.textContent=''; });

        // Collapse/Expand functionality
        const collapseBtn = document.getElementById('bp-collapse');
        const discPlayer = document.getElementById('discPlayer');

        if (collapseBtn && discPlayer) {
          collapseBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            bottomPlayer.classList.add('hidden');
            discPlayer.classList.remove('hidden');
            if (!audio.paused) {
              discPlayer.classList.add('playing');
            }
          });

          discPlayer.addEventListener('click', function() {
            discPlayer.classList.add('hidden');
            discPlayer.classList.remove('playing');
            bottomPlayer.classList.remove('hidden');
          });
        }

        // Update disc rotation based on play state
        audio.addEventListener('play', () => {
          if (discPlayer && !discPlayer.classList.contains('hidden')) {
            discPlayer.classList.add('playing');
          }
          // recently-played recording removed
        });

        audio.addEventListener('pause', () => {
          if (discPlayer) {
            discPlayer.classList.remove('playing');
          }
        });

        // Favorite functionality
        const favoriteBtn = document.getElementById('bp-favorite');
        
        function updateFavoriteButton() {
          if (favoriteBtn && currentSongId) {
            // Check if song is favorited
            fetch('/api/user/favorites')
              .then(res => res.json())
              .then(data => {
                if (data.favorites && data.favorites.includes(currentSongId)) {
                  favoriteBtn.classList.add('active');
                } else {
                  favoriteBtn.classList.remove('active');
                }
              })
              .catch(err => console.error('Error checking favorite status:', err));
          }
        }
        
        if (favoriteBtn) {
          favoriteBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            if (currentSongId) {
              toggleFavorite(currentSongId, this);
            }
          });
        }

        // Expose API
        window.globalPlayer = { setQueue, loadTrack, play, pause, togglePlay, getQueue: ()=>queue };
        // Signal to pages that the global player is ready
        try { window.dispatchEvent(new Event('globalPlayerReady')); console.log('[global player] ready'); } catch(e){ console.warn('[global player] ready dispatch failed', e); }

        // Make bottom player clickable to open full player page
        if (bottomPlayer) {
          bottomPlayer.addEventListener('click', function(e) {
            // Don't navigate if clicking on control buttons or slider
            if (e.target.closest('.bp-btn') || e.target.closest('.bp-controls') || e.target.id === 'bp-slider') {
              return;
            }
            if (currentSongId) {
              // Save playback state before navigating
              try {
                localStorage.setItem('player_resume', JSON.stringify({
                  songId: currentSongId,
                  currentTime: audio.currentTime,
                  paused: audio.paused
                }));
              } catch(e) { console.warn('Could not save player state', e); }
              setTimeout(function() {
                window.location.href = '/player/' + currentSongId;
              }, 100);
            }
          });
        }
      })();
    </script>
  <% } %>

  <!-- Play song in bottom bar function -->
  <script>
    window.playSongInBottomBar = function(songId) {
      console.log('[playSongInBottomBar] called with songId:', songId);
      
      if (!window.globalPlayer) {
        console.warn('[playSongInBottomBar] globalPlayer not available - falling back to player page');
        // Fallback: navigate to the standalone player page so the song can still be played
        try {
          window.location.href = '/player/' + songId;
        } catch (e) {
          console.error('Fallback navigation failed:', e);
        }
        return;
      }
      
      // Fetch song details and play in bottom bar
      fetch('/api/song/' + songId)
        .then(res => res.json())
        .then(song => {
          console.log('[playSongInBottomBar] fetched song:', song.title);
          // Get all songs as queue
          fetch('/api/songs')
            .then(res => res.json())
            .then(allSongs => {
              console.log('[playSongInBottomBar] fetched queue, length:', allSongs.length);
              window.globalPlayer.setQueue(allSongs);
              const idx = allSongs.findIndex(s => s._id === songId);
              console.log('[playSongInBottomBar] song index in queue:', idx);
              if (idx !== -1) {
                window.globalPlayer.loadTrack(idx);
                // Wait a moment for audio to load before playing
                setTimeout(() => {
                  console.log('[playSongInBottomBar] calling play()');
                  window.globalPlayer.play();
                }, 100);
              }
            });
        })
        .catch(err => console.error('Error playing song:', err));
    };
  </script>

  <!-- Navbar Dropdown Script -->
  <script>
    (function() {
      // Albums dropdown functionality
      const albumsTrigger = document.querySelector('.albums-trigger');
      const albumsDropdown = document.querySelector('.albums-dropdown');
      
      if (albumsTrigger && albumsDropdown) {
        albumsTrigger.addEventListener('click', function(e) {
          e.stopPropagation();
          albumsDropdown.classList.toggle('active');
          // Close user dropdown if open
          const userDropdown = document.querySelector('.user-dropdown');
          if (userDropdown) userDropdown.classList.remove('active');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function(event) {
          if (!albumsDropdown.contains(event.target)) {
            albumsDropdown.classList.remove('active');
          }
        });
      }

      // User dropdown functionality
      const userAvatarBtn = document.getElementById('userAvatarBtn');
      const userDropdown = document.querySelector('.user-dropdown');
      
      if (userAvatarBtn && userDropdown) {
        userAvatarBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          userDropdown.classList.toggle('active');
          // Close albums dropdown if open
          if (albumsDropdown) albumsDropdown.classList.remove('active');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function(event) {
          if (!userDropdown.contains(event.target)) {
            userDropdown.classList.remove('active');
          }
        });
      }
    })();

    // Favorite Toggle Function
    window.toggleFavorite = function(songId, button) {
      const isActive = button.classList.contains('active');
      const url = isActive ? `/favorites/remove/${songId}` : `/favorites/add/${songId}`;
      
      fetch(url, {
        method: 'POST',
        headers: {
          'Accept': 'application/json'
        }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          if (isActive) {
            button.classList.remove('active');
          } else {
            button.classList.add('active');
            // Add pop animation
            button.style.animation = 'heartPop 0.3s ease';
            setTimeout(() => {
              button.style.animation = '';
            }, 300);
          }
        }
      })
      .catch(error => {
        console.error('Error toggling favorite:', error);
      });
    };
  </script>

  <!-- Custom Modal System -->
  <div id="customModal" class="custom-modal">
    <div class="modal-overlay"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modalTitle"></h3>
        <button class="modal-close" onclick="window.closeModal()">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class="modal-body">
        <p id="modalMessage"></p>
        <input type="text" id="modalInput" class="modal-input" style="display:none;" />
      </div>
      <div class="modal-footer">
        <button id="modalCancel" class="modal-btn modal-btn-cancel" onclick="window.closeModal()">Cancel</button>
        <button id="modalConfirm" class="modal-btn modal-btn-confirm">Confirm</button>
      </div>
    </div>
  </div>

  <style>
    .custom-modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 10000;
      animation: fadeIn 0.2s ease;
    }

    .custom-modal.active {
      display: block;
    }

    .modal-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(4px);
    }

    .modal-content {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: var(--bg-secondary, #12121f);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 16px;
      min-width: 400px;
      max-width: 500px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
      animation: slideUp 0.3s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translate(-50%, -45%);
      }
      to {
        opacity: 1;
        transform: translate(-50%, -50%);
      }
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 24px 24px 16px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .modal-header h3 {
      margin: 0;
      font-size: 20px;
      font-weight: 700;
      color: var(--text-primary, #ffffff);
    }

    .modal-close {
      background: none;
      border: none;
      color: var(--text-muted, #a0a0c0);
      font-size: 20px;
      cursor: pointer;
      padding: 4px 8px;
      transition: color 0.2s;
    }

    .modal-close:hover {
      color: var(--text-primary, #ffffff);
    }

    .modal-body {
      padding: 24px;
    }

    .modal-body p {
      margin: 0 0 16px 0;
      color: var(--text-secondary, #e0e0ff);
      line-height: 1.6;
    }

    .modal-input {
      width: 100%;
      padding: 12px 16px;
      background: var(--bg-tertiary, #1a1a2e);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      color: var(--text-primary, #ffffff);
      font-size: 14px;
      font-family: inherit;
      transition: border-color 0.2s;
    }

    .modal-input:focus {
      outline: none;
      border-color: #667eea;
      box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 12px;
      padding: 16px 24px 24px;
    }

    .modal-btn {
      padding: 10px 24px;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }

    .modal-btn-cancel {
      background: rgba(255, 255, 255, 0.05);
      color: var(--text-secondary, #e0e0ff);
    }

    .modal-btn-cancel:hover {
      background: rgba(255, 255, 255, 0.1);
    }

    .modal-btn-confirm {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: #ffffff;
    }

    .modal-btn-confirm:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }

    .modal-btn-confirm.danger {
      background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
    }

    .modal-btn-confirm.danger:hover {
      box-shadow: 0 4px 12px rgba(255, 107, 107, 0.4);
    }
  </style>

  <script>
    // Custom Modal System
    window.showModal = function(options) {
      const modal = document.getElementById('customModal');
      const title = document.getElementById('modalTitle');
      const message = document.getElementById('modalMessage');
      const input = document.getElementById('modalInput');
      const confirmBtn = document.getElementById('modalConfirm');
      const cancelBtn = document.getElementById('modalCancel');

      title.textContent = options.title || 'Confirm';
      message.textContent = options.message || '';
      
      // Reset button classes
      confirmBtn.className = 'modal-btn modal-btn-confirm';
      if (options.danger) {
        confirmBtn.classList.add('danger');
      }
      confirmBtn.textContent = options.confirmText || 'Confirm';
      
      // Show/hide input
      if (options.input) {
        input.style.display = 'block';
        input.value = '';
        input.placeholder = options.placeholder || '';
        setTimeout(() => input.focus(), 100);
      } else {
        input.style.display = 'none';
      }

      // Show/hide cancel button
      if (options.showCancel === false) {
        cancelBtn.style.display = 'none';
      } else {
        cancelBtn.style.display = 'block';
      }

      modal.classList.add('active');

      // Handle confirm
      const handleConfirm = () => {
        if (options.input) {
          const value = input.value.trim();
          if (value && options.onConfirm) {
            options.onConfirm(value);
          }
        } else if (options.onConfirm) {
          options.onConfirm();
        }
        window.closeModal();
      };

      confirmBtn.onclick = handleConfirm;
      
      // Handle Enter key in input
      if (options.input) {
        input.onkeypress = (e) => {
          if (e.key === 'Enter') {
            handleConfirm();
          }
        };
      }

      // Close on overlay click
      modal.querySelector('.modal-overlay').onclick = window.closeModal;
    };

    window.closeModal = function() {
      const modal = document.getElementById('customModal');
      modal.classList.remove('active');
    };

    // Escape key to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        window.closeModal();
      }
    });
  </script>
</body>
</html>
