<div class="admin-modern-container">
  <div class="admin-modern-card">
    <div class="card-header">
      <div class="header-icon">
        <i class="fas fa-music"></i>
      </div>
      <h1 class="card-title">Edit Song</h1>
      <p class="card-subtitle">Update song metadata</p>
    </div>
    <form action="/admin/songs/edit/<%= song._id %>" method="POST" enctype="multipart/form-data" class="modern-form">
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">
            <i class="fas fa-heading"></i>
            Song Title
          </label>
          <input type="text" name="title" value="<%= song.title %>" required class="modern-input">
        </div>
        <div class="form-group">
          <label class="form-label">
            <i class="fas fa-user-music"></i>
            Artist Name
          </label>
          <input type="text" name="artist" value="<%= song.artist %>" required class="modern-input">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">
          <i class="fas fa-language"></i>
          Language
        </label>
        <div class="select-wrapper">
          <select name="language" required class="modern-select">
            <option value="Hindi" <%= song.language === 'Hindi' ? 'selected' : '' %>>Hindi</option>
            <option value="Punjabi" <%= song.language === 'Punjabi' ? 'selected' : '' %>>Punjabi</option>
            <option value="English" <%= song.language === 'English' ? 'selected' : '' %>>English</option>
            <option value="Other" <%= song.language === 'Other' ? 'selected' : '' %>>Other</option>
          </select>
          <i class="fas fa-chevron-down select-icon"></i>
        </div>
      </div>
      <div class="form-actions">
        <a href="/admin" class="btn-secondary">
          <i class="fas fa-arrow-left"></i>
          Back to Admin
        </a>
        <button type="submit" class="btn-primary">
          <i class="fas fa-save"></i>
          Save Changes
        </button>
      </div>
    </form>
  </div>
</div>
